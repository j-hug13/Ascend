<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Ascend.WorkoutPage"
             Title="Log Workouts">
    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20">
            <Label 
                Text="Select Category"
                FontSize="28"
                HorizontalOptions="Center" />

            <Button Text="Strength Training" Clicked="StrengthClicked"/>

            <Button Text="Flexibility &amp; Mobility" Clicked="FlexibilityClicked"/>

            <Button Text="Cardio" Clicked="CardioClicked"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>