<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Ascend.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Ascend"
    Title="Ascend">

    <TabBar>
        <ShellContent
            Title="Log Workouts"
            ContentTemplate="{DataTemplate local:WorkoutPage}"/>

        <ShellContent
            Title="Quests"
            ContentTemplate="{DataTemplate local:QuestsPage}"/>

        <ShellContent
            Title="Character"
            ContentTemplate="{DataTemplate local:CharacterPage}"/>

        <ShellContent
            Title="Achievements/Badges"
            ContentTemplate="{DataTemplate local:BadgesPage}"/>

        <ShellContent
            Title="History"
            ContentTemplate="{DataTemplate local:WorkoutHistoryPage}"/>
    </TabBar>
</Shell>
